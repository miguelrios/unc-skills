RECALL_DATABASE_URL=postgresql://recall:replace-me@127.0.0.1:55434/recall
RECALL_AUTH_REQUIRED=1
RECALL_TRUST_TAILSCALE_HEADERS=1
RECALL_TRUSTED_PROXY_UIDS=0,65534
RECALL_ALLOWED_TAILSCALE_USERS=owner@example.com
# Private raw archive. Keep the bucket private and scope the S3 credential to it.
# RECALL_ARCHIVE_BACKEND=r2
# RECALL_ARCHIVE_BUCKET=recall-raw-owner
# RECALL_ARCHIVE_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
# RECALL_ARCHIVE_REGION=auto
# RECALL_ARCHIVE_ACCESS_KEY_ID is injected by the deployment secret manager.
# RECALL_ARCHIVE_SECRET_ACCESS_KEY is injected by the deployment secret manager.
# RECALL_ARCHIVE_NAMESPACE_KEY is an independent base64-encoded 32-byte secret.
# Cloudflare management API tokens are neither required nor read by Recall.
# Canonical v2 cutover. Keep disabled until archive-check and migrations pass.
# RECALL_CANONICAL_V2_ENABLED=1
# RECALL_CANONICAL_INGEST_PUBLIC=1
# Route authenticated MCP reads exclusively through canonical tenant/source grants.
# RECALL_CANONICAL_MCP_ENABLED=1
# RECALL_TENANT_ID=tenant:personal
# RECALL_PRINCIPAL_ID=principal:owner
# Unified web/native connector administration. Keep disabled until schema 029,
# an independent encryption key, and an exact provider redirect are configured.
# RECALL_ADMIN_WEB_ENABLED=1
# RECALL_CONTROL_ENCRYPTION_KEY is injected by the deployment secret manager.
# Google is optional, but the three Google values are all-or-none.
# RECALL_GOOGLE_CLIENT_ID is injected by the deployment secret manager.
# RECALL_GOOGLE_CLIENT_SECRET is injected by the deployment secret manager.
# RECALL_GOOGLE_REDIRECT_URI=https://recall.example/admin/oauth/callback/google
# Optional hosted auth/transport rail. Use a scoped Composio project key with
# connected-account read and proxy-execute permissions; never a browser key.
# RECALL_COMPOSIO_API_KEY is injected by the deployment secret manager.
# RECALL_COMPOSIO_REDIRECT_URI=https://recall.example/admin/oauth/callback/composio
# Optional custom auth configs. Omit to use Composio-managed development auth.
# RECALL_COMPOSIO_AUTH_CONFIG_GMAIL=ac_replace_me
# RECALL_COMPOSIO_AUTH_CONFIG_GOOGLECALENDAR=ac_replace_me
# RECALL_COMPOSIO_AUTH_CONFIG_GOOGLECONTACTS=ac_replace_me
# RECALL_COMPOSIO_AUTH_CONFIG_GOOGLEDRIVE=ac_replace_me
# Comma-separated exact HTTPS hosts allowed for expiring document-export downloads.
# Keep empty to disable document body export through Composio.
# RECALL_COMPOSIO_BINARY_HOSTS=files.example.invalid
# Browser MCP clients must match this exact comma-separated allow-list.
# Non-browser agent clients normally omit Origin.
# RECALL_MCP_ALLOWED_ORIGINS=https://approved-agent.example
# RECALL_MCP_RESOURCE_URI=https://recall.example.com/mcp
# RECALL_AUTHORIZATION_SERVERS=https://identity.example.com
# Standards-based human MCP access. `descope` is a convenience preset over the same OIDC verifier.
# RECALL_MCP_AUTH_PROVIDER=descope
# RECALL_OIDC_ISSUER=https://api.descope.com/v1/apps/agentic/<project>/<mcp-server>
# RECALL_OIDC_JWKS_URI=https://api.descope.com/<project>/.well-known/jwks.json
# Optional company invitation email. Disabled unless the provider is explicit.
# Descope uses its configured user-invitation template and links to Recall's
# brain-specific setup page. Keep the management key server-side.
# RECALL_INVITATION_EMAIL_PROVIDER=descope
# RECALL_DESCOPE_PROJECT_ID=P_replace_me
# RECALL_DESCOPE_MGMT_KEY is injected by the deployment secret manager.
# Provider-neutral transactional email alternative:
# RECALL_INVITATION_EMAIL_PROVIDER=resend
# RECALL_INVITATION_EMAIL_FROM=Recall <recall@example.com>
# RECALL_INVITATION_EMAIL_API_KEY is injected by the deployment secret manager.
# Semantic retrieval is opt-in and fail-closed. Choose one profile from deploy/README.md.
# Managed Voyage example (recommended hosted profile):
# RECALL_EMBEDDING_PROTOCOL=voyage
# RECALL_EMBEDDING_URL=https://api.voyageai.com
# RECALL_EMBEDDING_APPROVED_URL=https://api.voyageai.com
# RECALL_EMBEDDING_KEY_ENV=VOYAGE_API_KEY
# VOYAGE_API_KEY is injected by the deployment secret manager; never commit it here.
# RECALL_EMBEDDING_MODEL=voyage-4
# RECALL_EMBEDDING_REVISION=voyage-4
# RECALL_EMBEDDING_DIMENSIONS=512
# RECALL_EMBEDDING_BATCH_SIZE=64
# Managed embedding workers may opt into 2-8 parallel document batches.
# RECALL_EMBEDDING_WORKERS=1
# Calibrate this against a private retrieval eval when changing embedding models.
# RECALL_SEMANTIC_MINIMUM_SIMILARITY=0.35
# Generic OpenAI-compatible services use RECALL_EMBEDDING_PROTOCOL=openai. Models
# such as Nomic may also require explicit query/document prefixes:
# RECALL_EMBEDDING_DOCUMENT_PREFIX="search_document: "
# RECALL_EMBEDDING_QUERY_PREFIX="search_query: "
# Pinned TEI/Qwen remains available as the private self-hosted profile.
# RECALL_LITELLM_URL=https://staging-router.example.com
# RECALL_LITELLM_APPROVED_URL=https://staging-router.example.com
# RECALL_LITELLM_MODEL=gpt-5.4-mini
# RECALL_LITELLM_KEY_FILE=/home/owner/.config/recall-brain/planner.key
# RECALL_PLANNER_SAMPLES=2
# RECALL_SEMANTIC_TIMEOUT_SECONDS=30
# RECALL_SEMANTIC_CACHE_SIZE=256
# RECALL_SEMANTIC_CACHE_TTL_SECONDS=900
LOG_LEVEL=INFO
