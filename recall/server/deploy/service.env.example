RECALL_AUTH_REQUIRED=1
RECALL_TRUST_TAILSCALE_HEADERS=1
RECALL_TRUSTED_PROXY_UIDS=0,65534
RECALL_ALLOWED_TAILSCALE_USERS=owner@example.com
