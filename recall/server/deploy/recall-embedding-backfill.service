[Unit]
Description=Recall resumable embedding backfill
After=recall-embedding-backfill-sidecar.service recall-brain.service
Requires=recall-embedding-backfill-sidecar.service

[Service]
Type=oneshot
TimeoutStartSec=infinity
WorkingDirectory=%h/services/recall-brain/recall/server
EnvironmentFile=%h/.config/recall-brain/service.env
ExecStart=/usr/bin/env RECALL_EMBEDDING_URL=http://127.0.0.1:8090 %h/.config/recall-brain/venv/bin/python -m recall_server.cli backfill-embeddings --batch-size 128 --max-batches 4
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.config/recall-brain
