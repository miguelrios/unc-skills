{
  "schema_version": 1,
  "deployment_name": "synthetic-recall-core",
  "image": "registry.example.invalid/recall-core@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
